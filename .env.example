# Environment configuration for rqm-ising
# Copy this file to .env and fill in values for your environment.
# The .env file is excluded from version control.

# ── Application ──────────────────────────────────────────────
RQM_ISING_ENV=development       # development | staging | production
RQM_ISING_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
RQM_ISING_HOST=0.0.0.0
RQM_ISING_PORT=8000

# ── Artifact Storage ─────────────────────────────────────────
# Local filesystem path for artifact storage.
# In production, this would be replaced by object storage.
RQM_ISING_ARTIFACT_DIR=./artifacts

# ── NVIDIA Ising Provider (optional) ─────────────────────────
# Set these when integrating with a live NVIDIA Ising backend.
# Leave blank to run in mock/stub mode (default for local dev).
NVIDIA_ISING_BASE_URL=
NVIDIA_ISING_API_KEY=
NVIDIA_ISING_TIMEOUT_SECONDS=30

# ── CORS (for rqm-studio integration) ────────────────────────
RQM_ISING_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
